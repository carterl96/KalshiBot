# ---- Kalshi ----
# Use "demo" for the sandbox, "prod" for real money.
KALSHI_ENV=demo
KALSHI_API_KEY_ID=
# Provide the RSA private key PEM inline (use \n for newlines) OR a file path.
KALSHI_PRIVATE_KEY=
KALSHI_PRIVATE_KEY_PATH=

# ---- Trading mode & safety ----
# Engine always boots in paper; flip to live from the admin panel.
START_MODE=paper
AUTOSTART=false
SERIES=KXBTC15M,KXBTCD

# ---- Risk defaults (USD) ----
STARTING_BALANCE=1000
MAX_PER_TRADE=20
MAX_PER_WINDOW=60
DAILY_LOSS_LIMIT=50
MAX_EXPOSURE=200
MAX_DRAWDOWN_PCT=15
KELLY_FRACTION=0.25

# ---- Strategy ----
MIN_EDGE=0.04
FEE_BUFFER=0.02
VOL_LOOKBACK_S=900

# ---- LLM meta-layer (Phase 2; optional) ----
LLM_ENABLED=false
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ---- Persistence ----
# SQLite for local/dev. On Railway, set to a Postgres URL:
#   postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./kalshibot.db

# ---- API / auth ----
ADMIN_PASSWORD=changeme
JWT_SECRET=change-me-to-a-long-random-string
CORS_ORIGINS=*
HOST=0.0.0.0
PORT=8000
